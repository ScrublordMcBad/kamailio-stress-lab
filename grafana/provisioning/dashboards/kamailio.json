{
  "id": null,
  "uid": "kamailio-exporter-min",
  "title": "Kamailio (kamailio_exporter)",
  "tags": ["kamailio", "sip", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Kamailio Up",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "kamailio_up", "legendFormat": "up", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "kamailio_core_uptime_uptime_total", "legendFormat": "uptime", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "SHM Fragments",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "kamailio_core_shmmem_fragments", "legendFormat": "fragments", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "TM: Waiting Transactions",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "kamailio_tm_stats_waiting", "legendFormat": "waiting", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Shared Memory (core.shmmem)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "kamailio_core_shmmem_total", "legendFormat": "total", "refId": "A" },
        { "expr": "kamailio_core_shmmem_free", "legendFormat": "free", "refId": "B" },
        { "expr": "kamailio_core_shmmem_used", "legendFormat": "used", "refId": "C" },
        { "expr": "kamailio_core_shmmem_real_used", "legendFormat": "real_used", "refId": "D" },
        { "expr": "kamailio_core_shmmem_max_used", "legendFormat": "max_used", "refId": "E" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "TM: Transaction Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(kamailio_tm_stats_total_total[5m])", "legendFormat": "total transactions/s", "refId": "A" },
        { "expr": "rate(kamailio_tm_stats_rpl_received_total[5m])", "legendFormat": "replies received/s", "refId": "B" },
        { "expr": "rate(kamailio_tm_stats_rpl_sent_total[5m])", "legendFormat": "replies sent/s", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "SL: Reply Codes (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (code) (rate(kamailio_sl_stats_codes_total[5m]))", "legendFormat": "{{code}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "TCP Connections",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "kamailio_core_tcp_info_readers", "legendFormat": "readers", "refId": "A" },
        { "expr": "kamailio_core_tcp_info_max_connections", "legendFormat": "max_connections", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    }
  ]
}
